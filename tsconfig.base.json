{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"],
    "paths": {
      "@zero-os/shared": ["./packages/shared/src"],
      "@zero-os/shared/*": ["./packages/shared/src/*"],
      "@zero-os/secrets": ["./packages/secrets/src"],
      "@zero-os/observe": ["./packages/observe/src"],
      "@zero-os/model": ["./packages/model/src"],
      "@zero-os/core": ["./packages/core/src"],
      "@zero-os/memory": ["./packages/memory/src"],
      "@zero-os/channel": ["./packages/channel/src"],
      "@zero-os/scheduler": ["./packages/scheduler/src"],
      "@zero-os/supervisor": ["./packages/supervisor/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
