{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "paths": {
      "@/*": ["./src/app/*"],
      "@zero-os/shared": ["../../packages/shared/src/browser.ts"],
      "@zero-os/observe": ["../../packages/observe/src/browser.ts"]
    }
  },
  "include": ["src"]
}
